{
  "name": "kiwix-tool-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter '*' build",
    "changeset": "changeset",
    "format": "oxfmt --write \"**/*.{js,jsx,ts,tsx,json,jsonc}\"",
    "format:check": "oxfmt --check \"**/*.{js,jsx,ts,tsx,json,jsonc}\"",
    "prepare": "husky",
    "release": "bun run build && changeset publish",
    "release:full": "bun install && bun run typecheck && bun run build && bun run version && git diff && printf '\\nReview the diff above, then press Enter to commit and publish...' && read -r _ && git add . && git commit -m \"Version packages\" && bun run release && git push --follow-tags",
    "version": "changeset version",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "ai": "^7.0.0-canary.139"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": "oxfmt --write"
  },
  "trustedDependencies": [
    "@openzim/libzim"
  ]
}
